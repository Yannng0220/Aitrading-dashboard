{
  "name": "ai-trading-nexus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2026-03-23 --kv AGENTS_STATE",
    "cf:deploy": "wrangler pages deploy dist",
    "cf:deploy:engine": "wrangler deploy -c engine-worker/wrangler.toml",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "powershell -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "terser": "^5.46.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.76.0"
  }
